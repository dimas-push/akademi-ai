# ═══════════════════════════════════════════
#  AkademiAI — Environment Variables
#  Copy this file to .env.local and fill in
# ═══════════════════════════════════════════

# Moodle / Elearning UBP Karawang
MOODLE_BASE_URL=https://elearning.ubpkarawang.ac.id
MOODLE_TOKEN=your_moodle_token_here
MOODLE_USER_ID=13592

# Untuk fitur Auto-Absen (login Moodle web)
MOODLE_USERNAME=username_elearning_kamu
MOODLE_PASSWORD=password_elearning_kamu

# Student profile (public, used in UI)
NEXT_PUBLIC_STUDENT_NAME=Nama Lengkap Mahasiswa
NEXT_PUBLIC_STUDENT_NIM=NIM_Mahasiswa

# Dashboard password (protects the app via middleware)
DASHBOARD_PASSWORD=your_dashboard_password_here

# Anthropic API (for AI Chat tab)
ANTHROPIC_API_KEY=sk-ant-...
