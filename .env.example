# ═══════════════════════════════════════════
#  AkademiAI — Environment Variables
#  Copy this file to .env.local and fill in
# ═══════════════════════════════════════════

# Moodle / Elearning UBP Karawang
MOODLE_BASE_URL=https://elearning.ubpkarawang.ac.id
MOODLE_TOKEN=your_new_token_here
MOODLE_USER_ID=13592

# Anthropic AI (for chatbot)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Next Auth Secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Optional: Supabase (for persistent storage)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_key
